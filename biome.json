{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "include": [
        "e2e/**",
        "**/__tests__/**",
        "test-utils/**",
        ".flue/**",
        "test-real-user-flow.ts"
      ],
      "linter": {
        "rules": {
          "correctness": {
            "noEmptyPattern": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ],
  "files": {
    "ignore": [
      "node_modules",
      "dist",
      "out",
      "*.gen.ts",
      "dist-electron",
      "e2e-report",
      "e2e-report.json",
      "e2e-report-html",
      "test-results",
      "playwright-report",
      "e2e/screenshots",
      ".agentdock",
      ".claude"
    ]
  }
}
